/* ===== RAIN ===== */
const canvas = document.getElementById('rain');
const ctx = canvas.getContext('2d');
let drops = [], W, H;

function initRain() {
  W = canvas.width = window.innerWidth;
  H = canvas.height = window.innerHeight;
  drops = Array.from({length: Math.floor(W / 5)}, () => ({
    x: Math.random() * W,
    y: Math.random() * H,
    l: 9 + Math.random() * 22,
    s: 1.4 + Math.random() * 3.5,
    o: 0.06 + Math.random() * 0.32
  }));
}
initRain();
window.addEventListener('resize', initRain);

(function rainLoop() {
  ctx.clearRect(0, 0, W, H);
  drops.forEach(d => {
    ctx.globalAlpha = d.o;
    ctx.strokeStyle = 'rgba(160, 205, 240, 0.8)';
    ctx.lineWidth = 0.7;
    ctx.beginPath();
    ctx.moveTo(d.x, d.y);
    ctx.lineTo(d.x - d.l * 0.15, d.y + d.l);
    ctx.stroke();
    d.y += d.s;
    d.x -= d.s * 0.15;
    if (d.y > H) { d.y = -d.l; d.x = Math.random() * W; }
  });
  ctx.globalAlpha = 1;
  requestAnimationFrame(rainLoop);
})();

/* ===== LIGHTNING ===== */
const flashEl = document.getElementById('flash');
function lightning() {
  const delay = 12000 + Math.random() * 22000;
  setTimeout(() => {
    flashEl.style.background = 'rgba(190, 220, 255, 0.14)';
    setTimeout(() => {
      flashEl.style.background = 'transparent';
      setTimeout(() => {
        flashEl.style.background = 'rgba(190, 220, 255, 0.08)';
        setTimeout(() => {
          flashEl.style.background = 'transparent';
          lightning();
        }, 80);
      }, 120);
    }, 70);
  }, delay);
}
lightning();

/* ===== THUNDER ===== */
let thunderOn = false, audioCtx = null;

function toggleThunder() {
  thunderOn = !thunderOn;
  document.getElementById('tbtn').textContent = '&#9889; Thunder: ' + (thunderOn ? 'On' : 'Off');
  if (thunderOn) playThunder();
}

function playThunder() {
  if (!thunderOn) return;
  if (!audioCtx) audioCtx = new (window.AudioContext || window.webkitAudioContext)();
  const buf = audioCtx.createBuffer(1, audioCtx.sampleRate * 2.8, audioCtx.sampleRate);
  const data = buf.getChannelData(0);
  for (let i = 0; i < data.length; i++) {
    data[i] = (Math.random() * 2 - 1) * Math.pow(1 - i / data.length, 1.7) * 0.28;
  }
  const src = audioCtx.createBufferSource();
  src.buffer = buf;
  const gain = audioCtx.createGain();
  gain.gain.setValueAtTime(0, audioCtx.currentTime);
  gain.gain.linearRampToValueAtTime(0.5, audioCtx.currentTime + 0.1);
  gain.gain.exponentialRampToValueAtTime(0.001, audioCtx.currentTime + 2.8);
  src.connect(gain);
  gain.connect(audioCtx.destination);
  src.start();
  setTimeout(playThunder, 7000 + Math.random() * 20000);
}

/* ===== NAV SCROLL ===== */
window.addEventListener('scroll', () => {
  document.getElementById('nav').classList.toggle('scrolled', window.scrollY > 60);
});

/* ===== SCROLL REVEAL ===== */
const observer = new IntersectionObserver(entries => {
  entries.forEach(e => {
    if (e.isIntersecting) e.target.classList.add('on');
  });
}, {threshold: 0.1});
document.querySelectorAll('.rv').forEach(el => observer.observe(el));
