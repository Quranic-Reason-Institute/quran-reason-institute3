let curCat = 'all', curQ = '';

function renderArts() {
  const grid = document.getElementById('art-grid');
  let list = ARTS;
  if (curCat !== 'all') list = list.filter(a => a.cat === curCat);
  if (curQ) {
    const q = curQ.toLowerCase();
    list = list.filter(a =>
      a.title.toLowerCase().includes(q) ||
      a.desc.toLowerCase().includes(q) ||
      a.verse.toLowerCase().includes(q)
    );
  }
  if (!list.length) {
    grid.innerHTML = '<div class="no-results">No articles found. Try different keywords.</div>';
    return;
  }
  grid.innerHTML = list.map(a => `
    <a href="${a.url}" target="_blank" rel="noopener" class="art-card">
      <div class="art-verse">Qur&apos;an ${a.verse}</div>
      <div class="art-title">${a.title}</div>
      <div class="art-desc">${a.desc}</div>
      <div class="art-arrow">Read Article &rarr;</div>
    </a>`).join('');
}

function setTab(cat, btn) {
  curCat = cat;
  document.querySelectorAll('.tab').forEach(b => b.classList.remove('on'));
  btn.classList.add('on');
  renderArts();
}

function doSearch(v) {
  curQ = v;
  renderArts();
}

renderArts();

