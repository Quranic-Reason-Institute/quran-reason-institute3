<!DOCTYPE html>

<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Qur&apos;an Reason Institute &mdash; Think. Reflect. Understand.</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,500;0,700;0,900;1,500;1,700&family=Source+Serif+4:ital,opsz,wght@0,8..60,300;0,8..60,400;0,8..60,600;1,8..60,300;1,8..60,400&family=Cinzel:wght@400;600;700&display=swap" rel="stylesheet">
<style>
/* ====== RESET ====== */
*, *::before, *::after { margin:0; padding:0; box-sizing:border-box; }
html { scroll-behavior:smooth; }

/* ====== VARIABLES ====== */
:root {
–bg:       #1E2D3D;
–bg2:      #243447;
–bg3:      #1A2534;
–bg4:      #162030;
–card:     #243447;
–card2:    #2a3d52;
–cream:    #F0E8D5;
–cream2:   #D8CEBC;
–cream3:   #A89C88;
–accent:   #C8B896;
–blue:     #7BB8D4;
–border:   rgba(200,184,150,0.18);
–border2:  rgba(200,184,150,0.08);
–glow:     rgba(200,184,150,0.06);
}

/* ====== BASE ====== */
body {
background: var(–bg);
color: var(–cream);
font-family: ‘Source Serif 4’, Georgia, serif;
font-size: 20px;
line-height: 1.85;
overflow-x: hidden;
}
::-webkit-scrollbar { width:5px; }
::-webkit-scrollbar-track { background:var(–bg4); }
::-webkit-scrollbar-thumb { background:rgba(200,184,150,0.3); }

/* ====== RAIN CANVAS ====== */
#rain {
position: fixed;
inset: 0;
pointer-events: none;
z-index: 0;
opacity: 0.45;
}

/* ====== LIGHTNING ====== */
#flash {
position: fixed;
inset: 0;
pointer-events: none;
z-index: 1;
background: transparent;
transition: background 0.05s ease;
}

/* ====== THUNDER BTN ====== */
#tbtn {
position: fixed;
bottom: 1.5rem;
right: 1.5rem;
z-index: 600;
background: rgba(30,45,61,0.92);
border: 1px solid var(–border);
color: var(–cream3);
padding: 0.5rem 1.1rem;
font-family: ‘Cinzel’, serif;
font-size: 0.68rem;
letter-spacing: 0.12em;
cursor: pointer;
backdrop-filter: blur(12px);
transition: all 0.3s;
}
#tbtn:hover { border-color:var(–accent); color:var(–accent); }

/* ====== NAV ====== */
nav {
position: fixed;
top: 0; left: 0; right: 0;
z-index: 400;
display: flex;
align-items: center;
justify-content: space-between;
padding: 1.2rem 3.5rem;
transition: all 0.45s ease;
}
nav.scrolled {
background: rgba(22,32,48,0.97);
backdrop-filter: blur(20px);
border-bottom: 1px solid var(–border);
padding: 0.85rem 3.5rem;
}
.nav-logo {
display: flex;
align-items: center;
gap: 0.85rem;
text-decoration: none;
}
.nav-logo img {
width: 38px;
height: 38px;
object-fit: contain;
filter: drop-shadow(0 0 8px rgba(200,184,150,0.3));
}
.nav-logo-text {
font-family: ‘Cinzel’, serif;
font-size: 0.72rem;
letter-spacing: 0.2em;
color: var(–cream);
line-height: 1.35;
}
.nav-logo-text span {
display: block;
font-size: 0.52rem;
color: var(–cream3);
letter-spacing: 0.38em;
}
.nav-links {
display: flex;
gap: 2rem;
list-style: none;
align-items: center;
}
.nav-links a {
font-family: ‘Cinzel’, serif;
font-size: 0.62rem;
letter-spacing: 0.2em;
color: var(–cream3);
text-decoration: none;
text-transform: uppercase;
transition: color 0.3s;
}
.nav-links a:hover { color: var(–accent); }
.nav-links .nav-pill {
border: 1px solid var(–border);
padding: 0.4rem 1.1rem;
color: var(–cream) !important;
transition: all 0.3s !important;
}
.nav-links .nav-pill:hover {
background: rgba(200,184,150,0.1);
border-color: var(–accent);
}

/* ====== HERO ====== */
#hero {
position: relative;
min-height: 100vh;
display: flex;
align-items: center;
justify-content: center;
text-align: center;
overflow: hidden;
}
.hero-bg {
position: absolute;
inset: 0;
background: url(‘data:image/jpeg;base64,’) center/cover no-repeat;
filter: brightness(0.22) saturate(0.5);
transform: scale(1.08);
transition: transform 30s ease;
}
#hero:hover .hero-bg { transform: scale(1.0); }
.hero-fade {
position: absolute;
inset: 0;
background: linear-gradient(
180deg,
rgba(30,45,61,0.6) 0%,
rgba(30,45,61,0.05) 40%,
rgba(30,45,61,0.72) 82%,
var(–bg) 100%
);
}
.hero-inner {
position: relative;
z-index: 2;
max-width: 820px;
padding: 2rem 1.5rem;
}
.hero-eyebrow {
font-family: ‘Cinzel’, serif;
font-size: 0.7rem;
letter-spacing: 0.6em;
color: rgba(240,232,213,0.45);
text-transform: uppercase;
margin-bottom: 1.3rem;
}
.hero-h1 {
font-family: ‘Playfair Display’, serif;
font-size: clamp(2.8rem, 7.5vw, 5.5rem);
font-weight: 900;
line-height: 1.05;
color: var(–cream);
text-shadow: 0 2px 50px rgba(0,0,0,0.95);
margin-bottom: 0.4rem;
}
.hero-h1 em {
font-style: italic;
color: var(–accent);
}
.hero-tagline {
font-family: ‘Cinzel’, serif;
font-size: 0.75rem;
letter-spacing: 0.5em;
color: rgba(200,184,150,0.45);
text-transform: uppercase;
margin-bottom: 2.2rem;
}
.hero-p {
font-size: 1.15rem;
color: rgba(240,232,213,0.65);
max-width: 530px;
margin: 0 auto 2.8rem;
line-height: 1.85;
font-weight: 300;
}
.hero-p strong { color: var(–cream); font-weight: 500; }
.hero-btns {
display: flex;
gap: 1rem;
justify-content: center;
flex-wrap: wrap;
}

/* ====== BUTTONS ====== */
.btn {
font-family: ‘Cinzel’, serif;
font-size: 0.7rem;
letter-spacing: 0.18em;
padding: 0.88rem 2.1rem;
text-decoration: none;
text-transform: uppercase;
transition: all 0.3s;
display: inline-block;
cursor: pointer;
border: none;
}
.btn-cream {
background: var(–cream);
color: var(–bg4);
font-weight: 600;
}
.btn-cream:hover {
background: var(–cream2);
transform: translateY(-2px);
box-shadow: 0 8px 28px rgba(200,184,150,0.25);
}
.btn-outline {
border: 1px solid var(–border);
color: var(–cream);
background: transparent;
}
.btn-outline:hover {
border-color: var(–accent);
color: var(–accent);
background: var(–glow);
}

/* ====== SCROLL CUE ====== */
.scroll-cue {
position: absolute;
bottom: 2rem;
left: 50%;
transform: translateX(-50%);
display: flex;
flex-direction: column;
align-items: center;
gap: 0.5rem;
font-family: ‘Cinzel’, serif;
font-size: 0.58rem;
letter-spacing: 0.4em;
color: rgba(200,184,150,0.25);
animation: pulse 3s ease-in-out infinite;
}
.scroll-cue::after {
content: ‘’;
width: 1px;
height: 50px;
background: linear-gradient(to bottom, rgba(200,184,150,0.4), transparent);
}
@keyframes pulse { 0%,100%{opacity:0.2} 50%{opacity:0.9} }

/* ====== SECTIONS ====== */
section { position: relative; z-index: 2; }
.wrap { max-width: 1120px; margin: 0 auto; padding: 6rem 2.5rem; }
.wrap-sm { max-width: 760px; margin: 0 auto; padding: 6rem 2.5rem; text-align: center; }

/* ====== SECTION LABELS ====== */
.eyebrow {
font-family: ‘Cinzel’, serif;
font-size: 0.64rem;
letter-spacing: 0.55em;
color: var(–accent);
text-transform: uppercase;
margin-bottom: 0.9rem;
display: flex;
align-items: center;
gap: 1rem;
}
.eyebrow::before {
content: ‘’;
width: 34px;
height: 1px;
background: var(–accent);
flex-shrink: 0;
}
.eyebrow-center {
justify-content: center;
}
.eyebrow-center::before { display: none; }
h2 {
font-family: ‘Playfair Display’, serif;
font-size: clamp(2rem, 4.2vw, 3.1rem);
font-weight: 700;
line-height: 1.2;
color: var(–cream);
margin-bottom: 1rem;
}
h2 em {
font-style: italic;
color: var(–accent);
}
.lead {
font-size: 1.1rem;
color: var(–cream3);
max-width: 660px;
line-height: 1.9;
margin-bottom: 3rem;
font-weight: 300;
}

/* ====== SPLIT LAYOUT (img + text) ====== */
.split {
display: grid;
grid-template-columns: 1fr 1fr;
align-items: stretch;
min-height: 480px;
}
.split-r { grid-template-columns: 1fr 1fr; }
.split-img {
position: relative;
overflow: hidden;
}
.split-img img {
width: 100%;
height: 100%;
object-fit: cover;
display: block;
transition: transform 0.8s ease, filter 0.5s ease;
}
.split-img:hover img {
transform: scale(1.04);
}
.split-img .img-cap {
position: absolute;
bottom: 0;
left: 0;
right: 0;
padding: 0.9rem 1.2rem;
background: linear-gradient(transparent, rgba(22,32,48,0.85));
font-family: ‘Source Serif 4’, serif;
font-size: 0.9rem;
color: rgba(240,232,213,0.65);
font-style: italic;
line-height: 1.5;
}
.split-text {
padding: 4rem 3.5rem;
display: flex;
flex-direction: column;
justify-content: center;
background: var(–bg2);
}

/* ====== VERSE PULL ====== */
.verse-pull {
border-left: 3px solid var(–accent);
padding: 1rem 1.4rem;
background: rgba(200,184,150,0.06);
margin-bottom: 1.6rem;
}
.verse-pull p {
font-family: ‘Playfair Display’, serif;
font-style: italic;
font-size: 1.05rem;
color: var(–cream2);
line-height: 1.75;
}
.verse-pull cite {
display: block;
margin-top: 0.5rem;
font-family: ‘Cinzel’, serif;
font-size: 0.62rem;
letter-spacing: 0.2em;
color: var(–accent);
font-style: normal;
}

/* ====== STATS ====== */
.stats-row {
display: grid;
grid-template-columns: repeat(4, 1fr);
gap: 1px;
background: var(–border2);
margin-top: 2.5rem;
}
.stat {
background: var(–bg2);
padding: 1.4rem 1rem;
text-align: center;
transition: background 0.3s;
}
.stat:hover { background: var(–card2); }
.stat-n {
font-family: ‘Playfair Display’, serif;
font-size: 2.2rem;
color: var(–accent);
display: block;
font-weight: 700;
}
.stat-l {
font-family: ‘Cinzel’, serif;
font-size: 0.54rem;
letter-spacing: 0.2em;
color: var(–cream3);
text-transform: uppercase;
margin-top: 0.2rem;
}

/* ====== FULL BANNER ====== */
.img-banner {
position: relative;
overflow: hidden;
height: 420px;
}
.img-banner img {
width: 100%;
height: 100%;
object-fit: cover;
display: block;
transition: transform 0.9s ease;
}
.img-banner:hover img { transform: scale(1.04); }
.img-banner-over {
position: absolute;
inset: 0;
display: flex;
align-items: center;
}
.img-banner-over-left {
background: linear-gradient(90deg, rgba(22,32,48,0.9) 40%, transparent 100%);
}
.img-banner-over-center {
background: rgba(22,32,48,0.6);
justify-content: center;
text-align: center;
}
.banner-inner {
padding: 0 4rem;
max-width: 520px;
}
.banner-inner-center {
padding: 0 2rem;
max-width: 660px;
}
.banner-h {
font-family: ‘Playfair Display’, serif;
font-size: clamp(1.6rem, 3.2vw, 2.4rem);
color: var(–cream);
font-weight: 700;
line-height: 1.22;
margin-bottom: 0.85rem;
}
.banner-p {
font-size: 1rem;
color: rgba(240,232,213,0.65);
line-height: 1.8;
margin-bottom: 1.3rem;
font-weight: 300;
}
.banner-ref {
font-family: ‘Cinzel’, serif;
font-size: 0.6rem;
letter-spacing: 0.22em;
color: var(–accent);
}

/* ====== LIBRARY ====== */
#library { background: var(–bg3); }
#search {
width: 100%;
padding: 1rem 1.4rem;
background: rgba(255,255,255,0.05);
border: 1px solid var(–border);
color: var(–cream);
font-family: ‘Source Serif 4’, serif;
font-size: 1rem;
outline: none;
transition: border 0.3s;
margin-bottom: 1.4rem;
}
#search::placeholder { color: var(–cream3); }
#search:focus { border-color: var(–accent); }
.tabs {
display: flex;
flex-wrap: wrap;
gap: 0.45rem;
margin-bottom: 2rem;
padding-bottom: 1.4rem;
border-bottom: 1px solid var(–border2);
}
.tab {
font-family: ‘Cinzel’, serif;
font-size: 0.58rem;
letter-spacing: 0.14em;
padding: 0.44rem 1rem;
background: transparent;
border: 1px solid var(–border2);
color: var(–cream3);
cursor: pointer;
transition: all 0.3s;
text-transform: uppercase;
}
.tab.on, .tab:hover {
border-color: var(–accent);
color: var(–accent);
background: var(–glow);
}
.tc {
font-size: 0.48rem;
background: var(–accent);
color: var(–bg4);
padding: 0.06rem 0.3rem;
margin-left: 0.28rem;
vertical-align: middle;
font-weight: 700;
}
.art-grid {
display: grid;
grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
gap: 0.85rem;
}
.art-card {
background: var(–card);
border: 1px solid var(–border2);
padding: 1.5rem 1.7rem;
text-decoration: none;
display: block;
transition: all 0.32s;
position: relative;
overflow: hidden;
}
.art-card::before {
content: ‘’;
position: absolute;
top: 0; left: 0; bottom: 0;
width: 3px;
background: var(–accent);
transform: scaleY(0);
transition: transform 0.32s;
transform-origin: bottom;
}
.art-card:hover {
background: var(–card2);
border-color: rgba(200,184,150,0.3);
transform: translateY(-3px);
box-shadow: 0 12px 35px rgba(0,0,0,0.4);
}
.art-card:hover::before { transform: scaleY(1); }
.art-verse {
font-family: ‘Cinzel’, serif;
font-size: 0.58rem;
letter-spacing: 0.24em;
color: var(–accent);
margin-bottom: 0.55rem;
opacity: 0.85;
}
.art-title {
font-family: ‘Playfair Display’, serif;
font-size: 1.04rem;
color: var(–cream);
line-height: 1.4;
margin-bottom: 0.55rem;
font-weight: 600;
}
.art-desc {
font-size: 0.88rem;
color: var(–cream3);
line-height: 1.62;
display: -webkit-box;
-webkit-line-clamp: 2;
-webkit-box-orient: vertical;
overflow: hidden;
}
.art-arrow {
color: var(–accent);
font-size: 0.88rem;
margin-top: 0.8rem;
display: inline-block;
transition: transform 0.3s;
}
.art-card:hover .art-arrow { transform: translateX(6px); }
.no-results {
grid-column: 1/-1;
text-align: center;
padding: 3rem;
color: var(–cream3);
font-family: ‘Cinzel’, serif;
font-size: 0.8rem;
letter-spacing: 0.15em;
}

/* ====== HADITH DEBATE ====== */
#debate { background: var(–bg4); }
.debate-layout {
display: grid;
grid-template-columns: 360px 1fr;
gap: 5rem;
align-items: start;
}
.debate-sticky {
position: sticky;
top: 7rem;
}
.debate-img {
width: 100%;
object-fit: cover;
display: block;
filter: grayscale(0.2);
}
.debate-img-cap {
margin-top: 0.8rem;
font-size: 0.9rem;
color: var(–cream3);
line-height: 1.6;
font-style: italic;
}
.debate-qv {
margin-top: 1.4rem;
padding: 1.1rem 1.35rem;
background: rgba(200,184,150,0.06);
border-left: 2px solid rgba(200,184,150,0.25);
}
.debate-qv p {
font-family: ‘Playfair Display’, serif;
font-style: italic;
font-size: 1rem;
color: var(–cream2);
line-height: 1.72;
}
.debate-qv cite {
display: block;
margin-top: 0.45rem;
font-family: ‘Cinzel’, serif;
font-size: 0.58rem;
letter-spacing: 0.18em;
color: var(–accent);
font-style: normal;
}
.debate-cards {
display: grid;
gap: 0.7rem;
}
.dc {
background: rgba(255,255,255,0.04);
border: 1px solid rgba(200,184,150,0.09);
cursor: pointer;
transition: all 0.3s;
overflow: hidden;
}
.dc:hover, .dc.open {
background: rgba(255,255,255,0.07);
border-color: rgba(200,184,150,0.3);
}
.dctop {
display: grid;
grid-template-columns: 46px 1fr 30px;
gap: 1rem;
align-items: center;
padding: 1.15rem 1.4rem;
}
.dcnum {
font-family: ‘Playfair Display’, serif;
font-size: 1.5rem;
color: rgba(200,184,150,0.15);
font-weight: 700;
line-height: 1;
text-align: center;
}
.dc.open .dcnum { color: rgba(200,184,150,0.55); }
.dclabel {
font-family: ‘Cinzel’, serif;
font-size: 0.52rem;
letter-spacing: 0.22em;
color: var(–cream3);
opacity: 0.6;
margin-bottom: 0.22rem;
}
.dcclaim {
font-family: ‘Playfair Display’, serif;
font-style: italic;
font-size: 0.95rem;
color: var(–cream2);
line-height: 1.4;
}
.dcplus {
font-size: 1.2rem;
color: rgba(200,184,150,0.25);
text-align: center;
line-height: 1;
transition: transform 0.35s, color 0.3s;
}
.dc.open .dcplus { transform: rotate(45deg); color: var(–accent); }
.dcbody {
max-height: 0;
overflow: hidden;
transition: max-height 0.45s ease;
}
.dc.open .dcbody { max-height: 300px; }
.dcinner {
padding: 0.1rem 1.4rem 1.35rem 4.2rem;
}
.dcrlabel {
font-family: ‘Cinzel’, serif;
font-size: 0.52rem;
letter-spacing: 0.22em;
color: var(–accent);
margin-bottom: 0.5rem;
opacity: 0.75;
}
.dcrtext {
font-size: 0.95rem;
color: var(–cream3);
line-height: 1.78;
margin-bottom: 0.65rem;
}
.dcrverse {
font-family: ‘Cinzel’, serif;
font-size: 0.58rem;
letter-spacing: 0.18em;
color: var(–accent);
opacity: 0.65;
}

/* ====== VERSE SECTION ====== */
#verse { background: var(–bg2); text-align: center; }
.arabic-text {
font-size: clamp(1.5rem, 5vw, 2.9rem);
color: var(–accent);
direction: rtl;
line-height: 2.2;
margin-bottom: 1.2rem;
}
.verse-trans {
font-family: ‘Playfair Display’, serif;
font-style: italic;
font-size: 1.2rem;
color: var(–cream);
max-width: 580px;
margin: 0 auto 0.65rem;
line-height: 1.85;
}
.verse-ref {
font-family: ‘Cinzel’, serif;
font-size: 0.65rem;
letter-spacing: 0.38em;
color: var(–accent);
}

/* ====== VIDEOS ====== */
#videos { background: var(–bg3); }
.video-grid {
display: grid;
grid-template-columns: 1fr 1fr;
gap: 1.1rem;
}
.vid-card {
background: var(–card);
border: 1px solid var(–border2);
overflow: hidden;
transition: all 0.35s;
}
.vid-card:hover {
border-color: rgba(200,184,150,0.35);
transform: translateY(-3px);
box-shadow: 0 14px 42px rgba(0,0,0,0.5);
}
.vid-wrap {
position: relative;
padding-bottom: 56.25%;
height: 0;
overflow: hidden;
}
.vid-wrap iframe {
position: absolute;
inset: 0;
width: 100%;
height: 100%;
border: none;
}
.vid-meta {
padding: 1.1rem 1.4rem;
border-top: 1px solid var(–border2);
}
.vid-ep {
font-family: ‘Cinzel’, serif;
font-size: 0.58rem;
letter-spacing: 0.3em;
color: var(–accent);
margin-bottom: 0.32rem;
}
.vid-title {
font-family: ‘Playfair Display’, serif;
font-size: 1rem;
color: var(–cream);
line-height: 1.4;
}

/* ====== TIKTOK ====== */
#tiktok {
background: var(–bg);
border-top: 1px solid var(–border);
border-bottom: 1px solid var(–border);
}
.tiktok-wrap {
max-width: 860px;
margin: 0 auto;
padding: 5rem 2.5rem;
display: flex;
align-items: center;
gap: 4rem;
}
.tiktok-text h2 {
font-family: ‘Playfair Display’, serif;
font-size: 2.3rem;
color: var(–cream);
margin-bottom: 0.9rem;
}
.tiktok-text p {
font-size: 1.05rem;
color: var(–cream3);
line-height: 1.85;
margin-bottom: 1.8rem;
font-weight: 300;
}
.tiktok-link {
display: inline-flex;
align-items: center;
gap: 0.7rem;
font-family: ‘Cinzel’, serif;
font-size: 0.7rem;
letter-spacing: 0.15em;
color: var(–cream);
text-decoration: none;
border: 1px solid var(–border);
padding: 0.88rem 1.7rem;
transition: all 0.3s;
}
.tiktok-link:hover {
background: var(–glow);
border-color: var(–accent);
